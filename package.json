{
  "name": "@nexus-cw/casket",
  "version": "0.1.0-alpha",
  "description": "Small, easy-to-use authenticated encryption library for Node.js. AES-256-GCM and ChaCha20-Poly1305 with Argon2id key derivation. Cross-compatible wire format with Casket (.NET).",
  "license": "MIT",
  "author": "dMonGirl",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPattern=tests/",
    "typecheck": "tsc --noEmit"
  },
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "argon2": "^0.31.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "@jest/globals": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  }
}
